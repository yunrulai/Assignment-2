# Example environment variables
PORT=3001
JWT_SECRET=change_this_secret

# MSSQL connection
DB_HOST=localhost
# If SQL Server uses a named instance, set DB_INSTANCE instead of DB_PORT.
# Example: DB_INSTANCE=SQLEXPRESS
DB_INSTANCE=
# Only set DB_PORT when connecting to a default instance by TCP port.
# Example: DB_PORT=1433
DB_PORT=
DB_USER=sa
DB_PASS=yourStrong(!)Password
DB_NAME=SecureShopDB
